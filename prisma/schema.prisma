generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  name      String 
  email     String    @unique 
  password  String 
  role      Role      @default(PATIENT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

enum Role {
  PATIENT 
  DOCTOR 
  ADMIN 
}
